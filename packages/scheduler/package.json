{
  "name": "@virio/scheduler",
  "version": "0.1.0",
  "description": "Off-chain scheduler for the Virio subscription protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test:e2e": "cd ../.. && node --import tsx/esm packages/scheduler/test/e2e.ts"
  },
  "dependencies": {
    "@virio/sdk": "*",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
